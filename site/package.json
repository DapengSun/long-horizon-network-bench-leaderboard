{
  "name": "leaderboard-mvp-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prod": "npm run generate:data:real && vite --mode production",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "seed:data:fake": "node scripts/seed-fake-leaderboard-data.js",
    "generate:data": "node scripts/generate-leaderboard-data.js",
    "generate:data:fake": "node scripts/generate-leaderboard-data.js --mode fake",
    "generate:data:real": "node scripts/generate-leaderboard-data.js --mode real"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "antd": "^6.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  }
}
